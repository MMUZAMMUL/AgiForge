{
  "manifest_version": 3,
  "name": "RepoDocs AI — Project Documentation Generator",
  "version": "1.0.0",
  "description": "Point it at any GitHub repo and get a professional 5-10 page PDF/DOCX with architecture diagrams, a feature mindmap, and an AI-written breakdown — generated entirely in your browser with your own free AI key.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/background.js",
    "type": "module"
  },
  "permissions": [
    "storage",
    "unlimitedStorage",
    "downloads",
    "offscreen",
    "alarms",
    "tabs",
    "activeTab",
    "scripting",
    "desktopCapture"
  ],
  "host_permissions": [
    "https://api.github.com/*",
    "https://raw.githubusercontent.com/*",
    "https://api.groq.com/*",
    "https://api.cerebras.ai/*",
    "https://generativelanguage.googleapis.com/*",
    "https://openrouter.ai/*"
  ],
  "optional_host_permissions": [
    "<all_urls>"
  ],
  "minimum_chrome_version": "116"
}
